# ============================================
# Configuration Ollama (LLM local gratuit)
# ============================================
# Modèles recommandés (à télécharger avec `ollama pull <nom>`):
#   - qwen2.5:7b-instruct  (recommandé : bon multilingue + tool calling)
#   - llama3.1:8b          (alternative : très bon tool calling)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TEMPERATURE=0.1

# keep_alive : combien de temps le modèle reste en RAM
OLLAMA_KEEP_ALIVE=24h

# Nombre max de tokens générés (plus petit = plus rapide)
OLLAMA_NUM_PREDICT=400

# ============================================
# Modèle d'embeddings (gratuit, local, multilingue)
# ============================================
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# ============================================
# Supabase
# ============================================
SUPABASE_URL=https://your-project.supabase.co
# IMPORTANT : utiliser la service_role KEY uniquement côté backend
# (ne JAMAIS l'exposer côté client — elle bypass les RLS)
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ============================================
# Paramètres RAG
# ============================================
# Seuil de similarité FAQ (0-1) : au-dessus de ce score, la question
# est traitée comme une FAQ. En-dessous, on passe en mode dynamique.
FAQ_SIMILARITY_THRESHOLD=0.78

# Nombre de documents FAQ à récupérer
FAQ_TOP_K=3

# Taille max de l'historique de conversation
MAX_HISTORY_MESSAGES=6
